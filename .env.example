MISTRAL_API_KEY=your_mistral_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ONISEP OpenData — https://opendata.onisep.fr
ONISEP_EMAIL=your_email_here
ONISEP_PASSWORD=your_password_here
ONISEP_APP_ID=your_app_id_here
ONISEP_USERNAME=your_username_here

# OPENAI_API_KEY is optional, only used for Phase F (7-system benchmark with GPT-4o)
OPENAI_API_KEY=your_openai_key_here

# France Travail API — https://francetravail.io (ordre Jarvis 2026-04-23, cf TODO_MATTEO_APIS.md §1)
# Rate limits par défaut : ROME 4.0 = 1 RPS | Anotéa = 8 RPS | Marché du travail = 10 RPS
FT_CLIENT_ID=your_ft_client_id_here
FT_CLIENT_SECRET=your_ft_client_secret_here

# La Bonne Alternance — https://api.apprentissage.beta.gouv.fr (cf TODO_MATTEO_APIS.md §3)
LBA_API_TOKEN=your_lba_bearer_token_here
