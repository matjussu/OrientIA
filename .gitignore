# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets
.env
.env.*
*.key

# Data (big files)
# Note : pattern `data/raw/*` (et non `data/raw/`) pour permettre les
# exceptions ci-dessous — limitation git : un dir exclu interdit toute
# ré-inclusion de fichiers à l'intérieur.
data/raw/*
# Exceptions : fixtures statiques nécessaires au workflow GHA D7
# (run_merge.py les lit, sinon il crash). Petits (~70 KB combinés).
# Refresh via ordres S2 D2 (ONISEP API live) + D4 (SecNumEdu scraper).
!data/raw/secnumedu.json
!data/raw/onisep_formations.json
# Exception Sprint 6 axe 4 — corpus financement curé manuellement depuis
# sources publiques. Non régénérable sans intervention humaine (pas un
# artefact de build), donc tracké pour reproductibilité.
!data/raw/financement/
!data/raw/financement/*.json
# Exception Sprint 6 axe 2 — corpus DROM-COM territorial curé depuis
# sources INSEE territorial + France Travail. Mêmes raisons.
!data/raw/domtom/
!data/raw/domtom/*.json
# Exception Sprint 8 W1 — corrections factuelles (5 erreurs persistantes
# user_test_v3). Curé manuellement, tracké pour reproductibilité.
!data/raw/corrections_factuelles/
!data/raw/corrections_factuelles/*.json
data/embeddings/*
results/raw_responses/

# Data processed volumineux (ADR-046) — générés par les pipelines
# d'ingestion et le merger v2. Régénérables via
# `python scripts/regenerate_processed.py` (pattern idempotent).
#
# Critère : fichier > 50 MB OU produit de re-build trivial (moins de 2 min
# d'API call). Ces fichiers sont des artefacts de build, pas des sources.
data/processed/formations.json
data/processed/formations.json.pre_dedup
data/processed/formations_dedupe.json
data/processed/formations_multi_corpus.json
data/processed/formations_multi_corpus_dedupe.json
data/processed/formations_multi_corpus_phaseB.json
data/processed/formations_multi_corpus_phaseC_dares.json
data/processed/formations_multi_corpus_phaseC_blocs.json
data/processed/france_comp_blocs_corpus.json
data/processed/inserjeunes_lycee_pro.json
data/processed/insersup_insertion.json
# Phase A.2 — ROME 4.0 corpus (12 MB, régénérable via `python -m src.collect.build_rome_corpus`)
data/processed/rome_metier_corpus.json
# Phase B finalisation — corpora annexes régénérables
data/processed/onisep_metiers_corpus.json
data/processed/doctorat_corpus.json
# Phase B output — corpus v5/v6/v7 (régénérables via `python -m src.collect.run_merge_v3`)
data/processed/formations_v5.json
data/processed/formations_v6.json
data/processed/formations_v7.json
# Backups intermédiaires (orphans pre-d5 et pipeline golden test)
data/processed/formations_golden_pipeline.json
data/processed/formations_unified.json
data/processed/formations_unified.pre_d5_backup.json
# Phase D archive — snapshots binaires des promotions corpus (v3.2, v5, v6...)
data/archive/

