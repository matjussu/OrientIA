# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Secrets
.env
.env.*
*.key

# Data (big files)
# Note : pattern `data/raw/*` (et non `data/raw/`) pour permettre les
# exceptions ci-dessous — limitation git : un dir exclu interdit toute
# ré-inclusion de fichiers à l'intérieur.
data/raw/*
# Exceptions : fixtures statiques nécessaires au workflow GHA D7
# (run_merge.py les lit, sinon il crash). Petits (~70 KB combinés).
# Refresh via ordres S2 D2 (ONISEP API live) + D4 (SecNumEdu scraper).
!data/raw/secnumedu.json
!data/raw/onisep_formations.json
data/embeddings/*
results/raw_responses/

# Data processed volumineux (GitHub soft limit 50 MB).
# Régénérable via `python -m src.collect.inserjeunes`. Pattern ADR-046
# pending pour formaliser gitignore + CI regenerate de TOUS les processed
# files (dont formations.json 81 MB, insersup_insertion 48 MB encore
# tracked pour ne pas casser les branches existantes).
data/processed/inserjeunes_lycee_pro.json

# Runtime logs
logs/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Zone identifiers (WSL artifacts)
*:Zone.Identifier
*:mshield

# Local-only docs (kept locally, not published)
V1.md
INRIA_AI_ORIENTATION_PROJECT.md
